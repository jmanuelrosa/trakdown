---
const githubUrl = "https://github.com/jmanuelrosa/trakdown";
---

<section id="install" class="px-6 pb-24 sm:pb-32" data-section="install">
  <div class="prose-column text-center">
    <hr class="mb-16" />
    <h2 class="display-lg">
      Stop copy-pasting. <span class="hl">Start capturing.</span>
    </h2>
    <p class="lede mt-6">
      Free, open source, shipping today. One install, three capture modes, every authenticated page you actually work in.
    </p>
    <div class="mt-10 flex flex-wrap gap-3 justify-center">
      <a
        href="#"
        class="btn btn-primary"
        data-umami-event="install_click"
        data-umami-event-location="final-cta"
      >Install for Chrome — Free</a>
      <a
        href={githubUrl}
        class="btn btn-ghost"
        data-umami-event="github_click"
        data-umami-event-location="final-cta"
      >View on GitHub</a>
    </div>
    <p class="small mt-6">
      MIT licensed · Privacy first · No telemetry
    </p>
  </div>
</section>
