---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "trakdown — Web page to markdown for AI workflows",
  description = "Chrome extension that captures any web page as clean markdown — even the ones behind your login. Pick an element, select text, or grab the page. Built for AI.",
  ogImage = "/og-image.png",
} = Astro.props;

const site = Astro.site ?? new URL("https://jmanuelrosa.github.io");
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith("/") ? baseRaw : `${baseRaw}/`;
const siteRoot = new URL(base, site).toString();
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImageUrl = new URL(`${base}${ogImage.replace(/^\//, "")}`, site).toString();

// Umami analytics (Cloud) — only injected on production builds AND only when the
// site is served from the canonical domain (data-domains filter). Dev / preview
// against localhost stays untracked even if the script accidentally loads.
const umamiId = import.meta.env.UMAMI_WEBSITE_ID;
const umamiEnabled = import.meta.env.PROD && Boolean(umamiId);
const umamiDomains = site.hostname;

// Schema.org SoftwareApplication — primary structured data for the product.
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "trakdown",
  description:
    "Chrome extension that captures any web page as clean markdown, including authenticated dashboards behind a login. Three modes: element picker, text selection, and full page.",
  applicationCategory: "BrowserApplication",
  applicationSubCategory: "DeveloperApplication",
  operatingSystem: "Chrome 138+",
  url: siteRoot,
  downloadUrl: "https://github.com/jmanuelrosa/trakdown/releases",
  softwareVersion: "0.0.1",
  license: "https://opensource.org/licenses/MIT",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Person",
    name: "Jose Manuel Rosa",
  },
  featureList: [
    "Element picker — hover, arrow-key resize, click to capture",
    "Text selection mode — markdown of any highlighted range",
    "Full-page mode — Readability-based extraction with raw fallback",
    "Works on authenticated pages (runs in your logged-in browser tab)",
    "Output to clipboard or .md file, no destination lock-in",
    "Keyboard shortcut for the picker (default ⌘⇧K)",
    "Private by default — page content never leaves your machine",
    "Open source, MIT licensed",
  ],
};

// WebSite schema — helps search engines understand the site identity.
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "trakdown",
  url: siteRoot,
  description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="trakdown — capture web pages as markdown" />
    <meta property="og:site_name" content="trakdown" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#FBF7EE" />
    <meta name="color-scheme" content="light" />
    <meta name="generator" content={Astro.generator} />

    <link rel="alternate" type="application/xml" href={`${base}sitemap.xml`} title="Sitemap" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400..700;1,400..700&family=Manrope:wght@300..700&display=swap"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(softwareSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />

    {umamiEnabled && (
      <script
        defer
        src="https://cloud.umami.is/script.js"
        data-website-id={umamiId}
        data-domains={umamiDomains}
      ></script>
    )}

    <slot name="head" />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
